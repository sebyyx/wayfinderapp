# Copy to .env and fill in. NEVER commit the real .env.

# ── Public (safe in the browser; inlined at build time) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ygqfxetqsldusdzfjlwu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id6781383516

# ── Server-only secrets (never exposed to the client) ────────────────────────
# Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated allowlist of admin emails (must have a Supabase auth account)
ADMIN_EMAILS=scosmor@gmail.com

# RevenueCat — exact MRR / trials / revenue / churn
# v2 SECRET API key from RevenueCat → Project Settings → API keys (starts with sk_)
REVENUECAT_API_KEY=
REVENUECAT_PROJECT_ID=proj56e798b8
# v1 "Secret API key" (RevenueCat → Project Settings → API keys → Secret keys).
# REQUIRED for admin tier upgrades/downgrades — they grant/revoke a promotional
# entitlement via the v1 subscriber API, which the v2 key above cannot do.
REVENUECAT_SECRET_KEY=
# Shared secret you set as the Authorization header on the RevenueCat webhook,
# pointing at https://admin.wayfinderapp.life/api/revenuecat/webhook
REVENUECAT_WEBHOOK_SECRET=
